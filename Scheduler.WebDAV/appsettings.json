{
  "Settings": {
    "AuditorAutoPurgeDays": 365
  },
  "ConnectionStrings": {
    "Scheduler": "Server=LOCALHOST;Database=Scheduler;Integrated Security=SSPI;TrustServerCertificate=true;",
    "Security": "Server=LOCALHOST;Database=Security;Integrated Security=SSPI;TrustServerCertificate=true;",
    "Auditor": "Server=LOCALHOST;Database=Auditor;Integrated Security=SSPI;TrustServerCertificate=true;"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5100"
      }
    }
  },
  "WebDAV": {
    "CredentialCacheTtlMinutes": 5,
    "MaxUploadSizeBytes": 1073741824
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
