{
    "outputPath": "dist/",
    "Settings": {
        "MultiTenancyMode": true,
        "AuditorMode": "DispatchToBackgroundImmediately",
        "DataVisibilityMode": true,
        "DiskBasedBinaryStorageMode": false,
        "DisableCrossSiteForgeryLogic": true,
        "UserToRunServicesAs": "SystemService",
        "SendGridAPIKey": "",
        "EmailFromAddress": "noreply@compactica.tech",
        "EmailDisplayName": "K2 Research",
        "EmailSignature": "K2 Research",
        "CompanyName": "K2 Research"
    },
    "ConnectionStrings": {
        "BMC": "Server=LOCALHOST;Database=BMC;Integrated Security=SSPI;TrustServerCertificate=true;",
        "Security": "Server=LOCALHOST;Database=Security;Integrated Security=SSPI;TrustServerCertificate=true;",
        "Auditor": "Server=LOCALHOST;Database=Auditor;Integrated Security=SSPI;TrustServerCertificate=true;"
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://0.0.0.0:12100"
            },
            "Https": {
                "Url": "https://0.0.0.0:12101"
            }
        },
        "Limits": {
            "MaxRequestBodySize": 104857600
        }
    },
    "ExternalLogin": {
        "Google": {
            "ClientId": "",
            "Issuer": "https://accounts.google.com",
            "ValidateIssuer": "true"
        },
        "Facebook": {
            "ClientId": "",
            "Issuer": "https://www.facebook.com",
            "ValidateIssuer": "true"
        },
        "Microsoft": {
            "ClientId": "",
            "Issuer": "https://login.microsoftonline.com/common/v2.0",
            "ValidateIssuer": "false"
        },
        "Twitter": {
            "ConsumerAPIKey": "",
            "ConsumerSecret": ""
        }
    },
    "OIDC": {
        "Certificate": "Certificates\\bmc.cert.pem",
        "Key": "Certificates\\bmc.key.pem"
    },
    "MonitoredApplications": [
        {
            "Name": "BMC",
            "Url": "https://localhost:12101",
            "IsSelf": true
        }
    ],
    "Logging": {
        "PathFormat": "Logs/log-{Date}.log",
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.AspNetCore.Server.Kestrel": "Warning"
        }
    },
    "ServiceAccount": {
        "Username": "SystemService",
        "Password": "bmc-service-2026-placeholder",
        "Enabled": true
    },
    "LogErrorNotification": {
        "Enabled": true,
        "SystemName": "BMC",
        "Environment": "Development",
        "EnableEmail": false,
        "NotificationEmails": [],
        "EmailFromAddress": "noreply@compactica.tech",
        "EmailFromName": "BMC System Monitor",
        "EnableAlerting": false,
        "AlertingSeverity": "High",
        "BatchWindowMinutes": 10,
        "MaxErrorsPerBatch": 100,
        "MinimumLevel": "Error"
    },
    "AllowedHosts": "*",
    "LDraw": {
        "DataPath": "./ldraw-data"
    }
}