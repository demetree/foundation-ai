{
  "outputPath": "dist/",
  "Settings": {
    "MultiTenancyMode": true,
    "AuditorMode": "DispatchToBackgroundImmediately",
    "DataVisibilityMode": true,
    "DiskBasedBinaryStorageMode": false,
    "DisableCrossSiteForgeryLogic": true,
    "UserToRunServicesAs": "Admin"
  },
  "ConnectionStrings": {
    "Scheduler": "Server=LOCALHOST;Database=Scheduler;Integrated Security=SSPI;TrustServerCertificate=true;",
    "Security": "Server=LOCALHOST;Database=SchedulerSecurity;Integrated Security=SSPI;TrustServerCertificate=true;",
    "Auditor": "Server=LOCALHOST;Database=Auditor;Integrated Security=SSPI;TrustServerCertificate=true;"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:10100"
      },
      "Https": {
        "Url": "https://0.0.0.0:10101"
        //"Certificate": {
        //  "Path": "certs/certificate.pfx",
        //  "Password": "your-password"
        //}
      }
    },
    "Limits": {
      "MaxRequestBodySize": 104857600
    }
  },
  "ExternalLogin": {
    // Google oidc configuration.
    "Google": {
      "ClientId": "",
      "Issuer": "https://accounts.google.com",
      "ValidateIssuer": "true"
    },
    // Facebook oidc configuration.
    "Facebook": {
      "ClientId": "",
      "Issuer": "https://www.facebook.com",
      "ValidateIssuer": "true"
    },
    // Microsoft oidc configuration.
    "Microsoft": {
      "ClientId": "",
      "Issuer": "https://login.microsoftonline.com/common/v2.0",
      "ValidateIssuer": "false"
    },
    // Twitter oauth configuration. https://developer.twitter.com/en/docs/basics/apps/overview
    "Twitter": {
      "ConsumerAPIKey": "",
      "ConsumerSecret": ""
    }
  },
  "OIDC": {
    "Certificate": "Certificates\\scheduler.cert.pem",
    "Key": "Certificates\\scheduler.key.pem"
  },

  "MonitoredApplications": [
    {
      "Name": "Scheduler",
      "Url": "https://localhost:10101",
      "IsSelf": true
    }
  ],

  // LogLevel Severity: "Trace", "Debug", "Information", "Warning", "Error", "Critical", "None"
  "Logging": {
    "PathFormat": "Logs/log-{Date}.log",
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Server.Kestrel": "Warning"
    }
  },
  "ServiceAccount": {
    "Username": "SystemService",
    "Password": "d80632a7-b1ff-47cb-9ecd-87f4a4a22763-Service2026!^#",
    "Enabled": true
  },
  "AllowedHosts": "*"
}