{
  "Conduit": {
    "MaxConnections": 10000,
    "IdleTimeoutSeconds": 300,
    "PingIntervalSeconds": 30,
    "MaxMessageSizeBytes": 65536,
    "MaxSubscribersPerChannel": 1000,
    "MaxChannelsPerConnection": 50,
    "ChannelHistoryDepth": 100
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:5107" }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
