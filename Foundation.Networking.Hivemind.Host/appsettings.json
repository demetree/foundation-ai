{
  "Hivemind": {
    "CacheDefaultTtlSeconds": 300,
    "CacheMaxEntries": 10000,
    "CacheEvictionStrategy": "LRU",
    "SessionDefaultTtlSeconds": 1800,
    "SessionSlidingExpiry": true,
    "PubSubMaxQueueDepth": 1000,
    "CleanupIntervalSeconds": 60
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:5104" }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
