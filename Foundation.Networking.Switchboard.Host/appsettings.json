{
  "Switchboard": {
    "Strategy": "RoundRobin",
    "HealthCheckIntervalSeconds": 30,
    "HealthCheckPath": "/api/health",
    "FailureThreshold": 3,
    "RecoveryThreshold": 2,
    "Backends": []
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:5103" }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
